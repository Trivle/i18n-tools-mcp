{
    "name": "@trivle/i18n-tools-mcp",
    "version": "0.1.0",
    "description": "MCP server for managing JSON translation files",
    "type": "module",
    "bin": {
        "i18n-tools-mcp": "./dist/index.js"
    },
    "files": [
        "dist",
        "!dist/**/*.test.*"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublishOnly": "pnpm build"
    },
    "packageManager": "pnpm@10.30.3",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "typescript": "^5.7.0",
        "vitest": "^4.0.18"
    }
}
